# ==========================================
# 🤖 CLAVES DE IA (MODELOS)
# ==========================================
# Generar en: https://aistudio.google.com/
GOOGLE_API_KEY="tu_api_key_de_gemini_aqui"

# Generar en: https://console.groq.com/
GROQ_API_KEY="tu_api_key_de_groq_aqui"


# ==========================================
# 📧 GMAIL API CREDENCIALES (OAuth)
# ==========================================
# Generar en: Google Cloud Console -> APIs & Services -> Credentials
GMAIL_CLIENT_ID="tu_id_de_cliente.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="tu_secreto_de_cliente_aqui"

# Opcional: Si usas el archivo .json completo que te da Google
# GOOGLE_APPLICATION_CREDENTIALS="credentials.json"


# ==========================================
# 🛠️ LANGSMITH (Opcional - Para depurar el grafo)
# ==========================================
# Muy recomendado para ver visualmente cómo fluyen los datos en LangGraph
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_API_KEY="tu_langchain_api_key_aqui"
LANGCHAIN_PROJECT="Email_Assistant_Local"